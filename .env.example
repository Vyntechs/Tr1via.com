# Copy to .env.local and fill in.

# Supabase (local dev: run `supabase start` and copy from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API — used for question generation
ANTHROPIC_API_KEY=

# Pexels — free, commercial-license stock photos (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Session cookie signing — generate with: openssl rand -base64 48
SESSION_SECRET=

# Public site URL — for QR codes & email magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── STRIPE (Trivia Nerd subscription — test mode) ───────────────────────
# Real values live in .env.local + Vercel, NEVER committed. Prefer a restricted
# key (rk_) over a secret key (sk_). The local webhook secret comes from
# `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=

# ─── TEST RUNNER (set via the orchestration script, never in prod) ───────
# Enables /api/_test/* routes for the test orchestrator. Routes additionally
# require the x-test-secret header to match TEST_SECRET; both must hold.
# Setting only one or neither = routes 404 (deny existence).
TEST_AUTH_ENABLED=
TEST_SECRET=

# Base URLs for the Anthropic + Pexels mock servers used by tests.
# When MOCK_EXTERNAL=1, instrumentation.ts boots MSW handlers that intercept
# calls to api.anthropic.com / api.pexels.com.
MOCK_EXTERNAL=
ANTHROPIC_BASE_URL=
PEXELS_BASE_URL=
