# Copy to .env.local and fill in.

# Supabase (local dev: run `supabase start` and copy from `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API — used for question generation
ANTHROPIC_API_KEY=

# Pexels — free, commercial-license stock photos (https://www.pexels.com/api/)
PEXELS_API_KEY=

# Session cookie signing — generate with: openssl rand -base64 48
SESSION_SECRET=

# Public site URL — for QR codes & email magic-link redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000
